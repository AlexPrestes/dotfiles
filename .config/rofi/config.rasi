configuration {
	modi: "drun,window";
	font: "UbuntuMono Nerd Font Regular 14";
	show-icons: true;
	terminal: "kitty";
	combi-modi: "drun,window";
	matching: "fuzzy";
  timeout {
      action: "kb-cancel";
      delay:  0;
  }
  filebrowser {
      directories-first: true;
      sorting-method:    "name";
  }
}
@theme "/usr/share/rofi/themes/Arc-Dark.rasi"
