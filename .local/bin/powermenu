#!/bin/bash

rofi_command="rofi -theme themes/powermenu.rasi -i "

#### Options ###
power_off="ůįź• Shutdown"
reboot="ůį§Ā Reboot"
lock="ůįĎł Lock Screen"
suspend="ůį§Ą Suspend"
hibernate="ůįÄ† Hibernate"
log_out="ůįćÉ Log Out"

# Variable passed to rofi
options="$power_off\n$reboot\n$suspend\n$hibernate\n$log_out\n$lock"

chosen="$(echo -e "$options" | $rofi_command -dmenu -mesg "Power Menu")"
case $chosen in
$lock)
  betterlockscreen -l dimblur
  ;;
$power_off)
  systemctl poweroff
  ;;
$reboot)
  systemctl reboot
  ;;
$log_out)
  loginctl terminate-session ${XDG_SESSION_ID-}
  ;;
esac
